# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        color_good = "#a3be8c"
        color_degraded = "#ebcb8b"
        color_bad = "#bf616a"
        interval = 1
        separator = "|"
}

order += "tztime local"
order += "volume master"
order += "cpu_usage"
order += "battery all"

tztime local {
        format = "%a,%b %-d | %-l:%M %p"
        # hack to centre things
        align = "center"
        min_width = 700
}

volume master {
        format = "󰕾 %volume"
        format_muted = " (%volume)"
}

battery all {
        format = "󰁹 %percentage"
        threshold_type=percentage
        low_threshold=20
}

cpu_usage {
        format = "󰻠 %usage"
        degraded_threshold = 90
        max_threshold = 95
}

