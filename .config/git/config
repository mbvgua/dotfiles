[user]
	name = mbvgua
	email = 105845499+mbvgua@users.noreply.github.com
	signingKey = /home/mbvgua/.ssh/id_ed25519_codeberg.pub
[core]
	editor = nvim
	symlink = true
	pager = diff-so-fancy | less --tabs=4 -RF
[init]
	defaultBranch = main
[commit]
	template = ~/.config/git/message
	gpgSign = true
[gpg]
	format = ssh
[status]
	submodulesummary = 1
[pull]
	rebase = false
[merge]
	tool = subl-merge
	conflictStyle = zdiff3
[alias]
    ; lol = log --graph --decorate --pretty=oneline --all --abbrev-commit
	lol = log --graph --decorate --pretty=format:'%C(yellow)%h%Creset - %C(bold blue)%d%Creset %s %Cgreen(%cr)%Creset' --all --abbrev-commit
	ao = remote add origin
	br = branch
	st = status
	co = commit
    coan = commit --amend --no-edit
    coa = commit --amend
	ch = checkout
    cl = clone
	last = log -1 HEAD
	visual = !subl-merge .
    contributors = shortlog -nse
	standup = log --since='yesterday' --author='mbvgua'
    mine = log --author='mbvgua'
    ; for cloning repos with submodules
    clrs = clone --recurse-submodules
    sur = submodule update --remote
    ; pull all remote branches into local working directory
	pa = "!git branch -r | grep -v \"\\->\" | while read remote; do git branch --track \"${remote#origin/}\" \"$remote\"; done && git fetch --all && git pull --all"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color]
	ui = true
[help]
	autocorrect = 3
[interactive]
	diffFilter = diff-so-fancy --patch
