# # MY MODS
# playback
unbind common space
unbind common c
unbind browser c
unbind common L
unbind common H
unbind common ^N
unbind common ^P

bind common space player-pause
bind common c win-toggle
bind browser c win-activate
bind common H player-prev
bind common L player-next
bind common ^P player-prev
bind common ^N player-next

# play all songs in artist/album
set continue=true

# quit without asking for confirmation
unbind common q
bind common q quit

# set theme
# amazon       jellybeans
# NOTE: add monokai theme in official repo=> https://github.com/cmus/cmus
colorscheme amazon

