# i3 config file (v4)
include keybinds.conf
include workspaces.conf
include layouts.conf


# set Tux as mod key
set $mod Mod4

# run my autostart.sh file
exec --no-startup-id ~/.config/i3/scripts/autostart.sh

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# follow mouse focus
focus_follows_mouse yes

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
        position top
        tray_output primary
        font pango:JetBrains Mono Nerd Font ExtraBold 16
        separator_symbol "|"
        # binding_mode_indicator no
        status_command i3status
        # 0-> top/bottom 4-> right/left
        padding 0 4px
        colors {
            background #000000
            statusline #ffffff
            separator #666666

            focused_workspace  #4c7899 #285577 #ffffff
            active_workspace   #333333 #5f676a #ffffff
            inactive_workspace #333333 #222222 #888888
            urgent_workspace   #2f343a #900000 #ffffff
            binding_mode       #2f343a #900000 #ffffff
        }
}
