#!/usr/bin/env bash

set -eou pipefail


LANG_PACKAGES=(
    perl lua python LuaJIT make gcc clang nodejs pnpm git git-lfs stow keyd
    clisp sbcl docker docker-buildx docker-compose base-devel libffi-devel
    bzip2-devel openssl openssl-devel readline
    python3-pipx python3-psutil python3-dbus-fast python3-xcffib
)
USERLAND_PACKAGES=(
    qtile bash tmux vim btop alacritty cmus gnome-themes-extra nerd-fonts
    qbittorrent scrot gparted wget curl bluez libspa-bluetooth xclip
    mariadb scrot sublime-merge void-repo-nonfree pipewire ripgrep alsa-pipewire
    zathura zathura-pdf-poppler zathura-pdf-mupdf zathura-ps zathura-ps zathura-cb zathura-djvu
    polkit xfce4 picom NetworkManager network-manager-applet rtkit blueman
    rofi dunst feh mpv brightnessctl redshift redshift-gtk btop ImageMagick
    unzip autoconf automake xset xrandr ffmpeg udisks2 udiskie
)
TEMP_DIR=$(mktemp -d)

usage() {
    echo "
    Install system confiuration files and programs instantly.

    Usage: $ $0 [OPTIONS]

    A list of options is listed below:

    -a, --all               perfom all needed system configurations
    -b, --base              install base packages and exit
    -c, --config            symlink dotfiles configurations with the system using stow
    -s, --services          symlink essential startup daemons in /var/services
    -d, --audio             configure system audio
    -t, --bluetooth         configure system bluetooth
    -n, --network           configure system network
    -h, ---help             print this help segment and exit
    "
}

cleanup() {
    # remove temp_dir created in a particular section
    rm -rf "$TEMP_DIR"
}

# when script exits, remove the temp dir created
trap cleanup EXIT

if [[ "$#" -eq 1 ]]; then 

    OPERATION="$1"

    case $OPERATION in
        "--all" | "-a" )
            for package in "${LANG_PACKAGES[@]}"; do
                sudo xbps-install -Su && sudo xbps-install "$package"
            done
            ;;
        "--base")
            echo "base"

            echo "installing fonts"
            install_fonts() {
                # currently using Firamono
                local fonts_dir="$HOME/.local/share/fonts"
                if [[ ! -d "$fonts_dir" ]]; then 
                    mkdir "$fonts_dir"
                fi

                cd $TEMP_DIR
                wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraMono.zip
                wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip

                unzip FiraMono.zip -d "$fonts_dir"
                unzip JetBrainsMono.zip -d "$fonts_dir"
                fc-cache -fv
            }

            install_fonts
            ;;
        "--config")
            echo "config"
            ;;
        "--services")
            echo "services"
            ;;
        "--audio")
            echo "audio"
            ;;
        "--bluetooth")
            echo "bluetooth"
            ;;
        "--network")
            echo "network"
            ;;
        "--help")
            echo "help"
            ;; 
        *)
            echo "Unkown option $OPERATION"
            echo "Use --help for usage information"
            exit 1
    esac
elif [[ "$#" -eq 0 ]]; then
    echo "No arguments were passed"
    usage
    exit 2
else
    echo "Too many argumants passed"
    usage
    exit 2
fi


