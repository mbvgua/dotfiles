#!/usr/bin/env bash

set -eou pipefail


LANG_PACKAGES=(
    perl lua python LuaJIT make gcc clang nodejs git git-lfs stow keyd
    clisp sbcl docker docker-buildx docker-compose base-devel libffi-devel
    bzip2-devel openssl openssl-devel readline bash-completion
    python3-pipx python3-psutil python3-dbus-fast python3-xcffib
    # packages not in default void
    psmisc tree
)
USERLAND_PACKAGES=(
    qtile xfce4 bash btop alacritty cmus gnome-themes-extra flameshot
    vim neovim tmux alacritty noto-fonts-emoji noto-fonts-ttf noto-fonts-cjk
    qbittorrent gparted wget curl bluez libspa-bluetooth xclip
    mariadb sublime-merge void-repo-nonfree pipewire ripgrep alsa-pipewire
    zathura zathura-pdf-poppler zathura-pdf-mupdf zathura-ps zathura-ps zathura-cb zathura-djvu
    polkit picom NetworkManager network-manager-applet rtkit blueman
    rofi dunst feh mpv brightnessctl redshift redshift-gtk btop ImageMagick
    unzip autoconf automake xset xrandr ffmpeg udisks2 udiskie
)
TEMP_DIR=$(mktemp -d)

usage() {
    echo "
    Install system confiuration files and programs instantly.

    Usage: $ $0 [OPTIONS]

    A list of options is listed below:

    -b, --base              install system packages and configurations
    -d, --dots              clone dotfiles and set them up
    -s, --services          symlink essential startup daemons
    -h, ---help             print this help segment and exit
    "
}

cleanup() {
    # remove temp_dir created in a particular section
    rm -rf "$TEMP_DIR"
}

# when script exits, remove the temp dir created
trap cleanup EXIT

if [[ "$#" -eq 1 ]]; then 

    OPERATION="$1"

    case $OPERATION in
        "--base" | "-b" )
            echo "Installing needed packages..."
            # TODO: conacatenate these two for loops
            for package in "${LANG_PACKAGES[@]}"; do
                sudo xbps-install -Syu "$package"
            done

            for package in "${USERLAND_PACKAGES[@]}"; do
                sudo xbps-install -Syu "$package"
            done

            echo "Installing system fonts..."
            install_fonts() {
                # currently using Firamono
                local fonts_dir="$HOME/.local/share/fonts"
                if [[ ! -d "$fonts_dir" ]]; then 
                    mkdir "$fonts_dir"
                fi

                cd $TEMP_DIR
                wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraMono.zip
                wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip

                unzip FiraMono.zip -d "$fonts_dir"
                unzip JetBrainsMono.zip -d "$fonts_dir"
                fc-cache -fv
            }
            install_fonts

            setup_audio() {
                sudo xbps-install pipewire alsa-pipewire wireplumber

                ln -s /usr/share/examples/wireplumber/10-wireplumber.conf /etc/pipewire/pipewire.conf.d/
                ln -s /usr/share/examples/pipewire/20-pipewire-pulse.conf /etc/pipewire/pipewire.conf.d/

                # enable pipewire and pipewire-pulse autostart
                if [ -e "/usr/share/applications/pipewire.desktop" ] && [ -e "/etc/xdg/autostart/" ]; then
                    ln -s /usr/share/applications/pipewire.desktop /etc/xdg/autostart/pipewire.desktop
                    ln -s /usr/share/applications/pipewire-pulse.desktop /etc/xdg/autostart/pipewire-pulse.desktop
                fi

                # alsa configuration
                ln -s /usr/share/alsa/alsa.conf.d/50-pipewire.conf /etc/alsa/conf.d
                ln -s /usr/share/alsa/alsa.conf.d/99-pipewire-default.conf /etc/alsa/conf.d
            }
            setup_audio

            # touchpad click support
            echo "Add touchpad click support..."
            sudo cp ./40-libinput-touchpad.conf /etc/X11/xorg.conf.d/

            # remapping keyboard keys with keyd
            echo "Remap keyboard layout with keyd..."
            sudo cp ./default.conf /etc/keyd/

            # install pnpm and its packages
            sudo npm install -g typescript diff-so-fancy

            # install pipx and some packages
            pipx install git-filter-repo yt-dlp fastapi
            ;;
        "--dots" | "-d")
            echo "Configure dotfiles..."

            setup_dots() {
                local DOTS_DIR="~/.dotfiles"
                local TARGET_BRANCH="xorg/void"

                git clone ssh://git@codeberg.org/mbugua/dotfiles.git "$DOTS_DIR"
                cd "$DOTS_DIR"
                # pull all remote branches locally
                git !git branch -r | \
                    grep -v "\->" | \
                    while read remote; do \
                        git branch --track "${remote#origin/}" "$remote"; \
                    done && \
                    git fetch --all && \
                    git pull --all
                git checkout "$TARGET_BRANCH"
                stow .
            }

            if [[ ! -d "$DOTS_DIR" ]]; then
                setup_dots
            else
                rm -rf "$DOTS_DIR"
                setup_dots
            fi
            ;;
        "--services" | "-s")
            echo "Configure system services to launch on startup..."

            startup_services() {
                local services=(
                    lightdm elogind NetworkManager bluetooth bluetoothd
                    containerd dbus docker mysqld keyd polkitd
                )

                for service in "${services[@]}"; do
                    if [[ ! -d "/etc/sv/$service" ]]; then
                        echo "$service not found in /etc/sv directory..."
                        echo "aborting operation"
                        echo "please install: $service"
                        exit 1
                    fi

                    # If present, symlink...
                    # FIX: it would be better to first recursively go through loop above
                    # then if all are present,now do this. if some are absent, add to a
                    # not_found array, then present list to user
                    sudo ln -s /etc/sv/"$service" /var/service
                done
            }
            startup_services
            ;;
        "--help" | "-h")
            usage
            ;;
        *)
            echo "Unkown option $OPERATION"
            echo "Use --help for usage information"
            exit 1
    esac
elif [[ "$#" -eq 0 ]]; then
    echo "No arguments were passed"
    usage
    exit 2
else
    echo "Too many argumants passed"
    usage
    exit 2
fi

