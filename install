#!/usr/bin/env bash

tools=(
    # dev tools
    "cpp perl lua python luajit make gcc clang"
    "git git-lfs diff-so-fancy stow keyd wget curl"
    "bash tmux nvim vim btop alacritty cmus"
    "docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin"
    # wm_tools
    "zathura zathura-pdf-poppler zathura-pdf-mupdf zathura-ps zathura-ps zathura-cb zathura-djvu"
    "deepin-screenshot rofi dunst feh picom brightnessctl redshift"
    "mpv network-manager-applet pamixer paplay pipewire-pulse"
    "lxappearance Thunar xfce4-power-manager xfce4-screensaver"
    "polkit unzip autoconf automake xset xrandr ImageMagick"
)


pkg_manager="dnf"

install_base(){
    sudo ${pkg_manager} install -y ${tools[@]}
}

